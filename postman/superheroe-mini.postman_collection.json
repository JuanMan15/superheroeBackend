{
  "info": {
    "name": "Superheroe Mini",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "heroId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health Home",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/home",
          "host": ["{{baseUrl}}"],
          "path": ["home"]
        }
      }
    },
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan\",\n  \"email\": \"juan.test@example.com\",\n  \"password\": \"12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"juan.test@example.com\",\n  \"password\": \"12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Heroes List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/heroes",
          "host": ["{{baseUrl}}"],
          "path": ["heroes"]
        }
      }
    },
    {
      "name": "Heroes Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre_heroe\": \"Iron Man\",\n  \"nombre_real\": \"Tony Stark\",\n  \"universo\": \"Marvel\",\n  \"poder_principal\": \"Armadura tecnologica\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/heroes",
          "host": ["{{baseUrl}}"],
          "path": ["heroes"]
        }
      }
    },
    {
      "name": "Favorites Add",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/favorites/{{heroId}}",
          "host": ["{{baseUrl}}"],
          "path": ["favorites", "{{heroId}}"]
        }
      }
    },
    {
      "name": "Favorites My",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/favorites/my",
          "host": ["{{baseUrl}}"],
          "path": ["favorites", "my"]
        }
      }
    },
    {
      "name": "Favorites Delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/favorites/{{heroId}}",
          "host": ["{{baseUrl}}"],
          "path": ["favorites", "{{heroId}}"]
        }
      }
    },
    {
      "name": "User Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/profile",
          "host": ["{{baseUrl}}"],
          "path": ["users", "profile"]
        }
      }
    }
  ]
}
